# ============================================
# API Rate Limiting Gateway - Environment Configuration
# ============================================
# Copy this file to .env and customize for your environment

# Application
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# JWT Authentication (REQUIRED in production)
# Generate a secure 256-bit key: openssl rand -base64 32
JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_EXPIRATION=86400000

# Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_RPH=1000

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Backend Service URLs
# Configure these to point to your actual backend services
SERVICES_USER_URL=http://user-service:8081
SERVICES_ORDER_URL=http://order-service:8082
SERVICES_PRODUCT_URL=http://product-service:8083

# Logging (optional)
# LOG_LEVEL_ROOT=WARN
# LOG_LEVEL_APP=INFO
